# Required — get yours at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Optional — set to "true" only for local dev behind a VPN that breaks SSL
DISABLE_SSL_VERIFY=false

# Optional — comma-separated allowed origins for CORS (backend only)
CORS_ORIGINS=https://cinema-time-black.vercel.app,http://localhost:3000
